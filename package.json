{
  "name": "@fatsolutions/cairo-abi-codec",
  "version": "1.0.0",
  "description": "Encode arbitrary Cairo structs to calldata",
  "type": "module",
  "main": "dist/encoder.js",
  "types": "dist/typed-encoder.d.ts",
  "exports": {
    ".": {
      "types": "./dist/typed-encoder.d.ts",
      "default": "./dist/typed-encoder.js"
    },
    "./untyped": {
      "types": "./dist/encoder.d.ts",
      "default": "./dist/encoder.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "node --test --experimental-strip-types 'src/**/*.test.ts'"
  },
  "keywords": ["starknet", "cairo", "encoding", "calldata", "abi"],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "abi-wan-kanabi": "^2.2.4",
    "starknet": "^9.4.2"
  }
}
