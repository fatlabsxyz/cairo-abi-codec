{
  "name": "@fatsolutions/cairo-abi-codec",
  "version": "0.0.3",
  "description": "Encode/decode arbitrary Cairo structs to calldata",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fatlabsxyz/cairo-abi-codec.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "main": "dist/typed-encoder.js",
  "types": "dist/typed-encoder.d.ts",
  "exports": {
    ".": {
      "types": "./dist/typed-encoder.d.ts",
      "default": "./dist/typed-encoder.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test --experimental-strip-types 'src/**/*.test.ts'",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version && pnpm install --ignore-scripts"
  },
  "keywords": [
    "starknet",
    "cairo",
    "encoding",
    "calldata",
    "abi"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "abi-wan-kanabi": "^2.2.4",
    "starknet": "^9.4.2"
  }
}
